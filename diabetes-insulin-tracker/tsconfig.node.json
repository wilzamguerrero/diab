{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    // Emit build artifacts to a temp dir so a compiled vite.config.js is never
    // written next to vite.config.ts (Vite loads .js over .ts, which would
    // shadow the real config and drop the dev API proxy).
    "outDir": "./node_modules/.tmp/tsnode"
  },
  "include": ["vite.config.ts"]
}
